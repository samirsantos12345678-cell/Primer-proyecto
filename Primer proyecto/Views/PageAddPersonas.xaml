<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Primer_proyecto.Views.PageAddPersonas"
             Title="PageAddPersonas">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">
            <Entry x:Name="Nombre" Placeholder="Nombre" />
            <Entry x:Name="Apellido" Placeholder="Apellido" />
            <DatePicker x:Name="FechaNac" />
            <Entry x:Name="Correo" Placeholder="Correo" />
            <Entry x:Name="Telefono" Placeholder="Teléfono" />

            <Button Text="Tomar foto" Clicked="TomarFoto_Clicked" />

            <Image Source="{Binding FotoBase64, Converter={StaticResource Base64ToImageSourceConverter}}"
                   HeightRequest="160"
                   Aspect="AspectFill" />

            <Button x:Name="btnguardar" Clicked="btnguardar_Clicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>